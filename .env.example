# Postgres connection string (required for API server)
# Local: postgres://user:password@localhost:5432/finance_tracker
# Docker: postgres://tracker:fdflkj234523jg@postgres:5432/tracker
DATABASE_URL=postgres://user:password@localhost:5432/finance_tracker

# API server port (default 3001)
# PORT=3001

# Frontend: API base URL (default http://localhost:3001)
# VITE_API_URL=http://localhost:3001

# Auth (required for login)
INITIAL_LOGIN=admin@example.com
INITIAL_PASSWORD=changeme

# Reset credentials to initial on startup (optional)
# RESET_CREDENTIALS=true

# Session secret (required in production)
SESSION_SECRET=your-random-secret-at-least-32-chars

# Cloudflare Tunnel token (optional — enables public HTTPS access for SMS webhook)
# Create a tunnel at https://one.dash.cloudflare.com → Networks → Tunnels,
# then paste the token here and start with: docker compose --profile tunnel up -d
# CLOUDFLARE_TUNNEL_TOKEN=
